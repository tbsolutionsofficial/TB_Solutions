rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /projects/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reviews/{docId} {
      // Public can read approved reviews; authenticated admin can read ALL (pending + approved)
      allow read: if resource.data.approved == true || request.auth != null;
      allow create: if request.resource.data.approved == false;
      allow update, delete: if request.auth != null;
    }

    match /banners/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /offers/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /adminSettings/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
